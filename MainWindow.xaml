<Window x:Class="JurassicCraftLauncher.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:JurassicCraftLauncher"
        mc:Ignorable="d"
        Title="{x:Static local:AppTexts.AppName}"
        Height="620" Width="960"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        Icon="JurassicCraftLauncher.ico">

    <Window.Resources>
        <!-- Los estilos globales se movieron a App.xaml -->
    </Window.Resources>
    
    <!-- ══ RAÍZ DE LA VENTANA ══ -->
    <Grid x:Name="WindowRoot" Background="Transparent" Width="960" Height="620">
        <!-- Contenedor Principal (Marco de la ventana) -->
        <Border CornerRadius="12" 
                Background="#0A0B0D"
                BorderBrush="#15E8B820"
                BorderThickness="1"
                MouseLeftButtonDown="Window_MouseLeftButtonDown"
                ClipToBounds="True">
            <Grid>
                <!-- ══ FONDO BASE (ISLA NUBLAR) ══ -->
                <Border CornerRadius="12">
                    <Border.Background>
                        <ImageBrush ImageSource="pack://application:,,,/background.png" 
                                    Stretch="UniformToFill" 
                                    Opacity="0.25"/>
                    </Border.Background>
                    <Grid>
                        <Border Background="#85020406" CornerRadius="11.5"/> 
                        <Border CornerRadius="11.5">
                            <Border.Background>
                                <RadialGradientBrush RadiusX="1.2" RadiusY="1.2" Center="0.5,0.5" GradientOrigin="0.5,0.5">
                                    <GradientStop Color="#00000000" Offset="0"/>
                                    <GradientStop Color="#80000000" Offset="1"/>
                                </RadialGradientBrush>
                            </Border.Background>
                        </Border>
                    </Grid>
                </Border>

            <Border VerticalAlignment="Center" 
                    HorizontalAlignment="Left"
                    Width="54" 
                    Height="240"
                    Background="#12000000" 
                    BorderBrush="#08E8B820" 
                    BorderThickness="1"
                    CornerRadius="27"
                    Margin="20,0,0,0"
                    Panel.ZIndex="10">
                <StackPanel VerticalAlignment="Center">
                    <!-- Icono Inicio -->
                    <Border x:Name="NavHome" 
                            Style="{StaticResource NavBtn}"
                            Margin="0,0,0,25" 
                            MouseLeftButtonDown="NavHome_Click">
                        <TextBlock Text="{x:Static local:AppTexts.NavIconHome}" 
                                   FontFamily="Segoe MDL2 Assets" 
                                   FontSize="22" 
                                   Foreground="#E8B820" 
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Icono Skins -->
                    <Border x:Name="NavSkins" 
                            Style="{StaticResource NavBtn}"
                            Margin="0,0,0,25" 
                            MouseLeftButtonDown="NavSkins_Click">
                        <TextBlock Text="{x:Static local:AppTexts.NavIconSkins}" 
                                   FontFamily="Segoe MDL2 Assets" 
                                   FontSize="20" 
                                   Foreground="#D0B890" 
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <!-- Icono Configuración -->
                    <Border x:Name="NavSettings" 
                            Style="{StaticResource NavBtn}"
                            MouseLeftButtonDown="NavSettings_Click">
                        <TextBlock Text="{x:Static local:AppTexts.NavIconSettings}" 
                                   FontFamily="Segoe MDL2 Assets" 
                                   FontSize="20" 
                                   Foreground="#D0B890" 
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- ── Perfil de Usuario (Global) ── -->
            <Border x:Name="PanelUsuario" 
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top" 
                    Margin="0,60,30,0" 
                    Visibility="Collapsed"
                    Panel.ZIndex="100">
                <Border Background="Transparent" 
                        CornerRadius="22" 
                        Padding="8">
                    <StackPanel Orientation="Horizontal">
                        <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock x:Name="UsernameLabel" 
                                           FontFamily="Consolas" 
                                           FontSize="13" 
                                           FontWeight="Bold" 
                                           Foreground="#D8C8A0"
                                           VerticalAlignment="Center"
                                           Margin="0,0,8,0"/>
                                <Button Style="{StaticResource IconBtn}" 
                                        Content="{x:Static local:AppTexts.UserEditIcon}" 
                                        Click="ActionEditUser_Event"
                                        ToolTip="{x:Static local:AppTexts.UserEditTooltip}"
                                        FontFamily="Segoe MDL2 Assets"
                                        FontSize="14"/>
                            </StackPanel>
                        </StackPanel>
                        
                        <Border Width="36" Height="36" 
                                CornerRadius="18" 
                                Background="#30E8B820" 
                                BorderBrush="#50E8B820" 
                                BorderThickness="1">
                            <TextBlock Text="{x:Static local:AppTexts.UserAvatarIcon}" 
                                       FontSize="16" 
                                       Foreground="#D8C8A0" 
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"
                                       Margin="0,0,0,2"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Border>


            <!-- ══ CONTENEDOR PRINCIPAL DINÁMICO ══ -->
            <Grid Margin="54,0,0,0">
                <ContentControl x:Name="ViewContainer"/>
            </Grid>


            <!-- ══ BARRA INFERIOR ══ -->
            <Border Height="32"
                    VerticalAlignment="Bottom"
                    CornerRadius="0,0,6,6">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Color="#00000000" Offset="0"/>
                        <GradientStop Color="#25000000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Línea divisora superior de la barra inferior -->
            <Border Height="1" VerticalAlignment="Bottom" Margin="0,0,0,32">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Color="#00E8B820" Offset="0"/>
                        <GradientStop Color="#18E8B820" Offset="0.5"/>
                        <GradientStop Color="#00E8B820" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Versión -->
            <TextBlock x:Name="VersionText" Text=""
                       FontFamily="Consolas"
                       FontSize="9"
                       Foreground="#18E8B820"
                       VerticalAlignment="Bottom"
                       HorizontalAlignment="Left"
                       Margin="18,0,0,10"/>

            <!-- Indicador servidor -->
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Bottom"
                        HorizontalAlignment="Right"
                        Margin="0,0,18,9">
                <Ellipse Width="6" Height="6"
                         Margin="0,0,5,0"
                         VerticalAlignment="Center">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#80FF40" Offset="0"/>
                            <GradientStop Color="#40CC20" Offset="1"/>
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                    <Ellipse.Effect>
                        <DropShadowEffect Color="#80FF40" BlurRadius="6" ShadowDepth="0" Opacity="0.9"/>
                    </Ellipse.Effect>
                </Ellipse>
                <TextBlock Text="{x:Static local:AppTexts.ServerActiveLabel}"
                           FontFamily="Consolas"
                           FontSize="9"
                           Foreground="#25E8B820"/>
            </StackPanel>

            <!-- ══ SISTEMA DE MODALES (POP-UPS) ══ -->
            <Grid x:Name="ModalLayer" Visibility="Collapsed" Panel.ZIndex="99">
                <!-- Fondo oscurecido profundo (Con bordes curvos para no tapar los de la ventana) -->
                <Border Background="#E0000000" CornerRadius="12" MouseLeftButtonDown="Window_MouseLeftButtonDown"/>
                
                <!-- Cuerpo del Popup -->
                <Border Width="450" 
                        VerticalAlignment="Center" 
                        HorizontalAlignment="Center"
                        CornerRadius="15"
                        BorderThickness="1"
                        Padding="30">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0.5,1">
                            <GradientStop Color="#FB121212" Offset="0"/>
                            <GradientStop Color="#FB0A0A0A" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <Border.BorderBrush>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#40E8B820" Offset="0"/>
                            <GradientStop Color="#15CC2222" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.BorderBrush>

                    <StackPanel>
                        <!-- Título -->
                        <TextBlock x:Name="ModalTitle"
                                   Text="{x:Static local:AppTexts.ModalDefaultTitle}"
                                   FontFamily="Impact"
                                   FontSize="16"
                                   Foreground="#E8B820"
                                   Margin="0,0,0,15"/>

                        <!-- Contenido / Mensaje -->
                        <TextBlock x:Name="ModalMessage"
                                   Text="{x:Static local:AppTexts.ModalDefaultMessage}"
                                   FontFamily="Consolas"
                                   FontSize="13"
                                   Foreground="#D8C8A0"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,20"
                                   LineHeight="18"/>

                        <!-- Campo de Texto (Opcional - Login) -->
                        <Grid x:Name="ModalInputContainer" Visibility="Collapsed" Margin="0,0,0,5">
                            <TextBox x:Name="ModalInputBox"
                                     Style="{StaticResource UserBox}"
                                     MaxLength="16"
                                     Height="42"
                                     VerticalContentAlignment="Center"
                                     Padding="10,0"
                                     TextChanged="ModalInputBox_TextChanged"/>
                            <TextBlock x:Name="ModalInputPlaceholder"
                                       Text="{x:Static local:AppTexts.ModalUserInputPlaceholder}"
                                       FontFamily="Consolas"
                                       FontSize="11"
                                       Foreground="#40E8B820"
                                       Margin="24,0,0,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Visibility="Visible"/>
                        </Grid>

                        <!-- Mensaje de Error del Input -->
                        <TextBlock x:Name="ModalInputError"
                                   Text=""
                                   FontFamily="Consolas"
                                   FontSize="10"
                                   Foreground="#FF6666"
                                   Margin="5,0,0,15"
                                   Height="18"
                                   Visibility="Hidden"/>


                        <!-- Contenedor de Botones -->
                        <StackPanel x:Name="ModalButtonsContainer" 
                                    Orientation="Horizontal" 
                                    HorizontalAlignment="Right">
                            <!-- Los botones se añadirán dinámicamente desde C# -->
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ══ BORDE VENTANA ══ -->
            <Border CornerRadius="12"
                    BorderThickness="1"
                    IsHitTestVisible="False">
                <Border.BorderBrush>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                        <GradientStop Color="#30E8B820" Offset="0"/>
                        <GradientStop Color="#15CC2222" Offset="1"/>
                    </LinearGradientBrush>
                </Border.BorderBrush>
            </Border>

            <!-- ══ BARRA DE CONTROL (Siempre en el Top del Z-Index) ══ -->
            <Grid VerticalAlignment="Top" Height="42" Panel.ZIndex="101" HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center" 
                            Margin="0,0,10,0">
                    <Button Style="{StaticResource WinBtn}" 
                            Content="{x:Static local:AppTexts.WinBtnMinimize}" 
                            Margin="0,0,4,0" 
                            Click="MinimizeButton_Click"/>
                    <Button Style="{StaticResource CloseBtn}" 
                            Content="{x:Static local:AppTexts.WinBtnClose}" 
                            Click="CloseButton_Click"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Grid>
</Window>

